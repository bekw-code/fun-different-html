<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Frequency Cascade</title><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:Arial,sans-serif;background:radial-gradient(circle,#1a1a2e,#16213e,#0f3460);display:flex;justify-content:center;align-items:center;min-height:100vh;color:#fff;user-select:none;margin:0;padding:0}.game-container{background:rgba(255,255,255,.05);border-radius:25px;padding:20px;backdrop-filter:blur(20px);border:2px solid rgba(255,255,255,.1);box-shadow:0 30px 60px rgba(0,0,0,.4),inset 0 1px 0 rgba(255,255,255,.1);max-width:400px;width:95vw;margin:0 auto}.title{text-align:center;font-size:32px;margin-bottom:20px;background:linear-gradient(45deg,#ff0080,#ff8c00,#40e0d0,#9370db,#ff1493);-webkit-background-clip:text;-webkit-text-fill-color:transparent;text-shadow:0 0 30px rgba(255,255,255,.5);animation:titleGlow 3s ease-in-out infinite alternate}@keyframes titleGlow{0%{filter:brightness(1) saturate(1)}100%{filter:brightness(1.3) saturate(1.5)}}.game-board{width:320px;height:420px;background:rgba(0,0,0,.4);border:3px solid rgba(255,255,255,.2);border-radius:15px;margin:0 auto 20px;position:relative;overflow:hidden;box-shadow:inset 0 0 50px rgba(0,0,0,.5)}.grid{display:grid;grid-template-columns:repeat(10,1fr);grid-template-rows:repeat(20,1fr);width:100%;height:100%}.cell{border:1px solid rgba(255,255,255,.05);transition:all .3s ease}.chakra-block{border:2px solid rgba(255,255,255,.3);border-radius:6px;position:relative;overflow:hidden}.chakra-block::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:linear-gradient(45deg,transparent,rgba(255,255,255,.3),transparent);animation:shimmer 2s infinite}@keyframes shimmer{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}.red{background:linear-gradient(45deg,#f00,#f44);box-shadow:0 0 20px #f00,inset 0 0 20px rgba(255,255,255,.2);animation:redPulse 1.5s ease-in-out infinite alternate}@keyframes redPulse{0%{box-shadow:0 0 20px #f00,inset 0 0 20px rgba(255,255,255,.2)}100%{box-shadow:0 0 40px #f00,0 0 60px #f00,inset 0 0 30px rgba(255,255,255,.3)}}.orange{background:linear-gradient(45deg,#ff8c00,#ffa500);box-shadow:0 0 20px #ff8c00,inset 0 0 20px rgba(255,255,255,.2);animation:orangePulse 1.7s ease-in-out infinite alternate}@keyframes orangePulse{0%{box-shadow:0 0 20px #ff8c00,inset 0 0 20px rgba(255,255,255,.2)}100%{box-shadow:0 0 40px #ff8c00,0 0 60px #ffa500,inset 0 0 30px rgba(255,255,255,.3)}}.yellow{background:linear-gradient(45deg,#ff0,gold);box-shadow:0 0 20px #ff0,inset 0 0 20px rgba(255,255,255,.2);animation:yellowPulse 1.9s ease-in-out infinite alternate}@keyframes yellowPulse{0%{box-shadow:0 0 20px #ff0,inset 0 0 20px rgba(255,255,255,.2)}100%{box-shadow:0 0 40px #ff0,0 0 60px gold,inset 0 0 30px rgba(255,255,255,.3)}}.green{background:linear-gradient(45deg,#0f0,#32cd32);box-shadow:0 0 20px #0f0,inset 0 0 20px rgba(255,255,255,.2);animation:greenPulse 2.1s ease-in-out infinite alternate}@keyframes greenPulse{0%{box-shadow:0 0 20px #0f0,inset 0 0 20px rgba(255,255,255,.2)}100%{box-shadow:0 0 40px #0f0,0 0 60px #32cd32,inset 0 0 30px rgba(255,255,255,.3)}}.blue{background:linear-gradient(45deg,#0080ff,#4169e1);box-shadow:0 0 20px #0080ff,inset 0 0 20px rgba(255,255,255,.2);animation:bluePulse 2.3s ease-in-out infinite alternate}@keyframes bluePulse{0%{box-shadow:0 0 20px #0080ff,inset 0 0 20px rgba(255,255,255,.2)}100%{box-shadow:0 0 40px #0080ff,0 0 60px #4169e1,inset 0 0 30px rgba(255,255,255,.3)}}.indigo{background:linear-gradient(45deg,#4b0082,#8a2be2);box-shadow:0 0 20px #4b0082,inset 0 0 20px rgba(255,255,255,.2);animation:indigoPulse 2.5s ease-in-out infinite alternate}@keyframes indigoPulse{0%{box-shadow:0 0 20px #4b0082,inset 0 0 20px rgba(255,255,255,.2)}100%{box-shadow:0 0 40px #4b0082,0 0 60px #8a2be2,inset 0 0 30px rgba(255,255,255,.3)}}.violet{background:linear-gradient(45deg,#8b00ff,#9400d3);box-shadow:0 0 20px #8b00ff,inset 0 0 20px rgba(255,255,255,.2);animation:violetPulse 2.7s ease-in-out infinite alternate}@keyframes violetPulse{0%{box-shadow:0 0 20px #8b00ff,inset 0 0 20px rgba(255,255,255,.2)}100%{box-shadow:0 0 40px #8b00ff,0 0 60px #9400d3,inset 0 0 30px rgba(255,255,255,.3)}}.stats{display:flex;justify-content:space-between;margin-bottom:20px;font-size:18px;font-weight:700}.controls{display:grid;grid-template-columns:1fr 2fr 1fr;gap:15px;margin-bottom:20px}.control-btn{background:linear-gradient(45deg,rgba(255,255,255,.1),rgba(255,255,255,.05));border:2px solid rgba(255,255,255,.3);border-radius:20px;color:#fff;font-size:18px;font-weight:700;padding:18px;cursor:pointer;transition:all .3s ease;backdrop-filter:blur(10px);box-shadow:0 8px 20px rgba(0,0,0,.3)}.control-btn:hover{background:linear-gradient(45deg,rgba(255,255,255,.2),rgba(255,255,255,.1));transform:translateY(-2px);box-shadow:0 12px 30px rgba(0,0,0,.4)}.control-btn:active{transform:translateY(0)}.drop-btn{grid-column:2;background:linear-gradient(45deg,#00ff88,#00cc6a);font-size:22px;animation:dropGlow 2s ease-in-out infinite alternate}@keyframes dropGlow{0%{box-shadow:0 8px 20px rgba(0,0,0,.3)}100%{box-shadow:0 8px 20px rgba(0,255,136,.4),0 0 30px rgba(0,255,136,.3)}}.meditation-mode{text-align:center;margin-top:20px}.breath-guide{width:100px;height:100px;border:4px solid rgba(255,255,255,.3);border-radius:50%;margin:15px auto;position:relative;overflow:hidden;box-shadow:0 0 30px rgba(255,255,255,.2)}.breath-indicator{width:100%;height:100%;background:radial-gradient(circle,rgba(0,255,255,.4),transparent);border-radius:50%;transform:scale(.3);transition:transform 4s ease-in-out}.current-piece{position:absolute;top:30px;left:50%;transform:translateX(-50%);z-index:10}.piece-block{width:30px;height:19px;display:inline-block;margin:1px;border-radius:4px}.frequency-display{text-align:center;margin:15px 0;font-size:16px;font-weight:700;background:linear-gradient(45deg,#ff6b6b,#4ecdc4,#45b7d1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:freqGlow 2s ease-in-out infinite alternate}@keyframes freqGlow{0%{filter:brightness(1)}100%{filter:brightness(1.4)}}.next-piece{position:absolute;top:10px;right:10px;background:rgba(0,0,0,.3);padding:10px;border-radius:10px;border:1px solid rgba(255,255,255,.2)}.next-piece-title{font-size:12px;text-align:center;margin-bottom:5px;opacity:.8}</style></head><body><div class="game-container"><h1 class="title">✨ FREQUENCY CASCADE 🌈</h1><div class="stats"><div>Score: <span id="score">0</span></div><div>Level: <span id="level">1</span></div><div>Lines: <span id="lines">0</span></div></div><div class="frequency-display" id="freq-display">🌈 Ready to harmonize with light... ✨</div><div class="game-board"><div class="grid" id="grid"></div><div class="next-piece"><div class="next-piece-title">NEXT</div><div id="next-piece-preview"></div></div></div><div class="controls"><button class="control-btn" id="rotate-btn">🔄</button><button class="control-btn drop-btn" id="drop-btn">⬇️ DROP</button><button class="control-btn" id="pause-btn">⏸️</button></div><div class="controls"><button class="control-btn" id="left-btn">⬅️</button><button class="control-btn" id="start-btn">▶️ START</button><button class="control-btn" id="right-btn">➡️</button></div><div class="meditation-mode"><div>🧘‍♀️ Breathing with Light</div><div class="breath-guide"><div class="breath-indicator" id="breath-indicator"></div></div></div></div><script>const lightFreqs={red:430,orange:480,yellow:520,green:550,blue:620,indigo:680,violet:750};const lightColors=['red','orange','yellow','green','blue','indigo','violet'];let gameState={grid:Array(20).fill().map(()=>Array(10).fill(null)),currentPiece:null,nextPiece:null,piecePos:{x:3,y:0},score:0,level:1,lines:0,gameRunning:false,dropInterval:null};let audioCtx;const pieces=[{shape:[[1,1,1,1]],color:'red'},{shape:[[1,1],[1,1]],color:'orange'},{shape:[[0,1,0],[1,1,1]],color:'yellow'},{shape:[[0,1,1],[1,1,0]],color:'green'},{shape:[[1,1,0],[0,1,1]],color:'blue'},{shape:[[1,0,0],[1,1,1]],color:'indigo'},{shape:[[0,0,1],[1,1,1]],color:'violet'}];function init(){createGrid();setupControls();setupBreathing();generateNextPiece();spawnPiece()}function createGrid(){const grid=document.getElementById('grid');grid.innerHTML='';for(let i=0;i<200;i++){const cell=document.createElement('div');cell.className='cell';cell.dataset.index=i;grid.appendChild(cell)}}function setupControls(){document.getElementById('start-btn').onclick=startGame;document.getElementById('pause-btn').onclick=pauseGame;document.getElementById('left-btn').onclick=()=>movePiece(-1,0);document.getElementById('right-btn').onclick=()=>movePiece(1,0);document.getElementById('rotate-btn').onclick=rotatePiece;document.getElementById('drop-btn').onclick=dropPiece}function startGame(){if(!audioCtx)audioCtx=new(window.AudioContext||window.webkitAudioContext)();gameState.gameRunning=true;gameState.dropInterval=setInterval(gameLoop,Math.max(1000-(gameState.level*50),100));document.getElementById('start-btn').textContent='🔄 RESET';playFrequency(lightFreqs.green,.3,500)}function pauseGame(){gameState.gameRunning=!gameState.gameRunning;if(gameState.gameRunning){gameState.dropInterval=setInterval(gameLoop,Math.max(1000-(gameState.level*50),100));document.getElementById('pause-btn').textContent='⏸️'}else{clearInterval(gameState.dropInterval);document.getElementById('pause-btn').textContent='▶️'}}function generateNextPiece(){gameState.nextPiece=JSON.parse(JSON.stringify(pieces[Math.floor(Math.random()*pieces.length)]));renderNextPiece()}function spawnPiece(){if(gameState.nextPiece){gameState.currentPiece=gameState.nextPiece;generateNextPiece()}else{gameState.currentPiece=JSON.parse(JSON.stringify(pieces[Math.floor(Math.random()*pieces.length)]));generateNextPiece()}gameState.piecePos={x:3,y:0};updateFrequencyDisplay(gameState.currentPiece.color);renderCurrentPiece();if(!canMove(0,0)){gameOver()}}function renderNextPiece(){const nextEl=document.getElementById('next-piece-preview');nextEl.innerHTML='';if(gameState.nextPiece){gameState.nextPiece.shape.forEach(row=>{const rowDiv=document.createElement('div');rowDiv.style.display='flex';row.forEach(cell=>{const block=document.createElement('div');block.style.width='12px';block.style.height='12px';block.style.margin='1px';block.style.borderRadius='2px';if(cell){block.className=`chakra-block ${gameState.nextPiece.color}`}rowDiv.appendChild(block)});nextEl.appendChild(rowDiv)})}}function updateFrequencyDisplay(color){const freq=lightFreqs[color];document.getElementById('freq-display').textContent=`🌈 ${color.toUpperCase()} Light - ${freq}Hz ✨`}function renderCurrentPiece(){}function canMove(dx,dy){const newX=gameState.piecePos.x+dx;const newY=gameState.piecePos.y+dy;for(let y=0;y<gameState.currentPiece.shape.length;y++){for(let x=0;x<gameState.currentPiece.shape[y].length;x++){if(gameState.currentPiece.shape[y][x]){const gridX=newX+x;const gridY=newY+y;if(gridX<0||gridX>=10||gridY>=20)return false;if(gridY>=0&&gameState.grid[gridY][gridX])return false}}}return true}function movePiece(dx,dy){if(!gameState.gameRunning)return;if(canMove(dx,dy)){gameState.piecePos.x+=dx;gameState.piecePos.y+=dy;renderGame()}}function rotatePiece(){if(!gameState.gameRunning)return;const rotated=gameState.currentPiece.shape[0].map((_,i)=>gameState.currentPiece.shape.map(row=>row[i]).reverse());const original=gameState.currentPiece.shape;gameState.currentPiece.shape=rotated;if(!canMove(0,0)){gameState.currentPiece.shape=original}else{playFrequency(lightFreqs[gameState.currentPiece.color],.2,200)}renderGame()}function dropPiece(){if(!gameState.gameRunning)return;while(canMove(0,1)){gameState.piecePos.y++}placePiece()}function placePiece(){for(let y=0;y<gameState.currentPiece.shape.length;y++){for(let x=0;x<gameState.currentPiece.shape[y].length;x++){if(gameState.currentPiece.shape[y][x]){const gridX=gameState.piecePos.x+x;const gridY=gameState.piecePos.y+y;if(gridY>=0){gameState.grid[gridY][gridX]=gameState.currentPiece.color}}}}playFrequency(lightFreqs[gameState.currentPiece.color],.4,300);checkLines();spawnPiece();renderGame()}function checkLines(){let linesCleared=0;for(let y=19;y>=0;y--){if(gameState.grid[y].every(cell=>cell!==null)){playLineFrequency(linesCleared);gameState.grid.splice(y,1);gameState.grid.unshift(Array(10).fill(null));linesCleared++;y++}}if(linesCleared>0){gameState.lines+=linesCleared;gameState.score+=linesCleared*100*gameState.level;gameState.level=Math.floor(gameState.lines/10)+1;clearInterval(gameState.dropInterval);if(gameState.gameRunning){gameState.dropInterval=setInterval(gameLoop,Math.max(1000-(gameState.level*50),100))}updateStats()}}function playLineFrequency(lineNum){const baseFreq=528;const freq=baseFreq+(lineNum*100);playFrequency(freq,.6,800)}function playFrequency(freq,volume=.3,duration=200){if(!audioCtx)return;const osc=audioCtx.createOscillator();const gain=audioCtx.createGain();osc.connect(gain);gain.connect(audioCtx.destination);osc.frequency.value=freq;osc.type='sine';gain.gain.setValueAtTime(0,audioCtx.currentTime);gain.gain.linearRampToValueAtTime(volume,audioCtx.currentTime+.01);gain.gain.exponentialRampToValueAtTime(.001,audioCtx.currentTime+duration/1000);osc.start(audioCtx.currentTime);osc.stop(audioCtx.currentTime+duration/1000)}function gameLoop(){if(!gameState.gameRunning)return;if(canMove(0,1)){gameState.piecePos.y++}else{placePiece()}renderGame()}function renderGame(){const cells=document.querySelectorAll('.cell');cells.forEach((cell,i)=>{const x=i%10;const y=Math.floor(i/10);cell.className='cell';if(gameState.grid[y][x]){cell.classList.add('chakra-block',gameState.grid[y][x])}if(gameState.currentPiece){for(let py=0;py<gameState.currentPiece.shape.length;py++){for(let px=0;px<gameState.currentPiece.shape[py].length;px++){if(gameState.currentPiece.shape[py][px]){const pieceX=gameState.piecePos.x+px;const pieceY=gameState.piecePos.y+py;if(pieceX===x&&pieceY===y&&pieceY>=0){cell.classList.add('chakra-block',gameState.currentPiece.color)}}}}}})}function updateStats(){document.getElementById('score').textContent=gameState.score;document.getElementById('level').textContent=gameState.level;document.getElementById('lines').textContent=gameState.lines}function setupBreathing(){let breathing=false;setInterval(()=>{const indicator=document.getElementById('breath-indicator');breathing=!breathing;indicator.style.transform=breathing?'scale(1)':'scale(.3)'},4000)}function gameOver(){gameState.gameRunning=false;clearInterval(gameState.dropInterval);playFrequency(200,.5,1000);alert('🌟 Light Frequency Journey Complete! You harmonized '+gameState.lines+' lines! ✨');gameState.grid=Array(20).fill().map(()=>Array(10).fill(null));gameState.score=0;gameState.level=1;gameState.lines=0;updateStats();renderGame();document.getElementById('start-btn').textContent='▶️ START'}init()</script></body></html>
